{
	"name": "savemony",
	"private": true,
	"engines": {
		"node": ">=18.0.0"
	},
	"scripts": {
		"db:reset": "node scripts/reset-db.mjs",
		"dev:api": "pnpm --filter @savemony/api dev",
		"dev:frontend": "pnpm --filter @savemony/frontend dev",
		"dev": "pnpm run dev:api & pnpm run dev:frontend",
		"build:frontend": "pnpm --filter @savemony/frontend build",
		"build": "pnpm run build:frontend && pnpm --filter @savemony/api build",
		"lint": "pnpm -r run lint",
		"test": "pnpm -r run test",
		"test:api": "pnpm --filter @savemony/api test",
		"test:frontend": "pnpm --filter @savemony/frontend test",
		"db:generate": "pnpm --filter @savemony/api db:generate",
		"db:migrate": "pnpm --filter @savemony/api db:migrate",
		"db:studio": "pnpm --filter @savemony/api db:studio",
		"deploy:api": "pnpm --filter @savemony/api deploy",
		"clean": "pnpm -r exec rm -rf dist node_modules/.cache"
	},
	"devDependencies": {
		"@biomejs/biome": "2.5.2",
		"typescript": "~6.0.3"
	}
}